digraph G {
  graph [fontname="Microsoft YaHei", rankdir=LR, bgcolor="white", pad=0.25, nodesep=0.45, ranksep=0.65];
  node [fontname="Microsoft YaHei", shape=box, style="rounded,filled", color="#344054", fillcolor="#f8fafc"];
  edge [fontname="Microsoft YaHei", color="#475467", arrowsize=0.8];

  milestone [label="PM 创建 Milestone\n按 4 周实训阶段拆分", fillcolor="#fff7ed"];
  issue [label="创建 Issue\n目标、验收、负责人、截止时间"];
  design [label="需求/接口/表结构确认\nPM + 系统分析师"];
  branch [label="从 dev 拉 feature 分支"];
  code [label="开发与本地自测\nmvn clean verify / 前端检查"];
  pr [label="提交 PR 到 dev\n关联 Issue"];
  ci [label="GitHub Actions\n构建与测试"];
  review [label="Code Review\n至少 1 人 Approve"];
  merge [label="Squash and merge\n删除 feature 分支"];
  release [label="dev -> main\n阶段发布 / tag / 答辩版本"];

  milestone -> issue -> design -> branch -> code -> pr -> ci -> review -> merge -> release;
  ci -> code [label="失败修复", color="#d92d20"];
  review -> code [label="需修改", color="#d92d20"];
}
